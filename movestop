Add-Type -AssemblyName System.Windows.Forms; $r = New-Object Random; $expected = [System.Windows.Forms.Cursor]::Position; while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $expected.X -or $cur.Y -ne $expected.Y) { Write-Host "User moved mouse - paused"; $expected = $cur; Start-Sleep -Milliseconds 500 } else { $nx = $r.Next(0,[System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Width); $ny = $r.Next(0,[System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Height); [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point($nx,$ny); $expected = [System.Windows.Forms.Cursor]::Position; Start-Sleep -Milliseconds 500 } }
