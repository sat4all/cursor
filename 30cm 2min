Add-Type -AssemblyName System.Windows.Forms; $expected = [System.Windows.Forms.Cursor]::Position; $right = $true; $paused = $false; $lastMove = Get-Date; while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $expected.X -or $cur.Y -ne $expected.Y) { if (-not $paused) { Write-Host "User moved - paused" }; $paused = $true; $expected = $cur; $lastMove = Get-Date; Start-Sleep -Milliseconds 500 } else { if ($paused) { Write-Host "User stopped - resuming now"; $paused = $false } elseif ((Get-Date) - $lastMove -lt [TimeSpan]::FromMinutes(2)) { Start-Sleep -Milliseconds 500; continue }; $nx = if ($right) { $cur.X + 1134 } else { $cur.X - 1134 }; $right = -not $right; [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point($nx, $cur.Y); $expected = [System.Windows.Forms.Cursor]::Position; $lastMove = Get-Date; Write-Host "Auto moved - next move in 2 min"; Start-Sleep -Milliseconds 500 } }
