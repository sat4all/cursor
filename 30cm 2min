Add-Type -AssemblyName System.Windows.Forms; $expected = [System.Windows.Forms.Cursor]::Position; $right = $true; while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $expected.X -or $cur.Y -ne $expected.Y) { Write-Host "User moved - paused"; $expected = $cur; $right = $true; Start-Sleep -Milliseconds 120000 } else { $nx = if ($right) { $cur.X + 1134 } else { $cur.X - 1134 }; $right = -not $right; [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point($nx, $cur.Y); $expected = [System.Windows.Forms.Cursor]::Position; Write-Host "Auto moved - next move in 2 min"; Start-Sleep -Milliseconds 120000 } }
