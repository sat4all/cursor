Add-Type -AssemblyName System.Windows.Forms; $expected = [System.Windows.Forms.Cursor]::Position; $up = $true; while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $expected.X -or $cur.Y -ne $expected.Y) { Write-Host "User moved - paused"; $expected = $cur; $up = $true; Start-Sleep -Milliseconds 500 } else { $ny = if ($up) { $cur.Y - 38 } else { $cur.Y + 38 }; $up = -not $up; [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point($cur.X, $ny); $expected = [System.Windows.Forms.Cursor]::Position; Start-Sleep -Milliseconds 500 } }
