$script = 'Add-Type -AssemblyName System.Windows.Forms; $r = New-Object Random; $locked = [System.Windows.Forms.Cursor]::Position; $hidden = $false; try { while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $locked.X -or $cur.Y -ne $locked.Y) { if ($hidden) { [System.Windows.Forms.Cursor]::Show(); $hidden = $false }; $locked = $cur; Start-Sleep -Milliseconds 500 } else { if (-not $hidden) { [System.Windows.Forms.Cursor]::Hide(); $hidden = $true }; [System.Windows.Forms.Cursor]::Position = $locked; Start-Sleep -Milliseconds 100 } } } finally { [System.Windows.Forms.Cursor]::Show() }'; $f = "$env:TEMP\cursorlock.ps1"; $script | Out-File $f -Encoding UTF8; Start-Process powershell -WindowStyle Hidden -ArgumentList "-NonInteractive -ExecutionPolicy Bypass -File "$f""; exit
