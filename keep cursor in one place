Add-Type -AssemblyName System.Windows.Forms; $r = New-Object Random; $locked = [System.Windows.Forms.Cursor]::Position; $hidden = $false; try { while ($true) { $cur = [System.Windows.Forms.Cursor]::Position; if ($cur.X -ne $locked.X -or $cur.Y -ne $locked.Y) { if ($hidden) { [System.Windows.Forms.Cursor]::Show(); $hidden = $false; Write-Host "User moved - cursor visible" }; $locked = $cur; Start-Sleep -Milliseconds 500 } else { if (-not $hidden) { [System.Windows.Forms.Cursor]::Hide(); $hidden = $true; Write-Host "Idle - cursor hidden and locked" }; [System.Windows.Forms.Cursor]::Position = $locked; Start-Sleep -Milliseconds 100 } } } finally { [System.Windows.Forms.Cursor]::Show(); Write-Host "Cursor restored." }
